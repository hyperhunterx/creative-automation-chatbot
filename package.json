{
  "name": "shop-chat-agent",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "shopify app dev",
    "dev:plain": "react-router dev",
    "build": "prisma generate && react-router build",
    "start": "npx prisma migrate deploy && react-router-serve ./build/server/index.js",
    "docker-start": "react-router-serve ./build/server/index.js",
    "prepare": "prisma generate",
    "lint": "eslint --ignore-path .gitignore --cache --cache-location ./node_modules/.cache/eslint .",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "node prisma/seed.js",
    "postinstall": "prisma generate",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "cross-env INTEGRATION=1 vitest run --testTimeout=20000",
    "eval": "cross-env EVAL=1 node tests/eval/run.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "@prisma/client": "^6.19.1",
    "@react-router/dev": "7.11.0",
    "@react-router/fs-routes": "7.11.0",
    "@react-router/node": "7.11.0",
    "@react-router/serve": "7.11.0",
    "@shopify/app-bridge-react": "^4.1.6",
    "@shopify/shopify-app-react-router": "^1.0.0",
    "@shopify/shopify-app-session-storage-prisma": "^7.0.0",
    "algoliasearch": "^5.52.1",
    "cohere-ai": "^7.21.0",
    "dotenv": "^16.3.1",
    "isbot": "^5.1.0",
    "openai": "^6.37.0",
    "posthog-node": "^4.0.0",
    "prisma": "6.19.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router": "7.11.0",
    "uuid": "^9.0.0",
    "vite-tsconfig-paths": "^5.0.1",
    "voyageai": "^0.0.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.31",
    "@types/uuid": "^9.0.0",
    "@vitest/coverage-v8": "^1.6.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.38.0",
    "prettier": "^3.2.4",
    "typescript": "^5.2.2",
    "vite": "^6.2.2",
    "vitest": "^1.6.0"
  },
  "workspaces": [
    "extensions/*"
  ],
  "author": "Shahid Afrid"
}
