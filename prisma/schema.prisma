// This is your Prisma schema file for PostgreSQL (Railway)
// Production-ready schema with chat history, leads, and analytics

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// PRODUCT INDEX (RAG retrieval source)
// ============================================

model Product {
  id            String   @id                  // Shopify GID, e.g. "gid://shopify/Product/123"
  handle        String
  title         String
  vendor        String?                       // brand
  productType   String?                       // raw Shopify product_type
  category      String?                       // normalized category (v1 = productType)
  tags          String[]
  description   String?                       // HTML stripped
  priceMin      Decimal? @db.Decimal(12, 2)
  priceMax      Decimal? @db.Decimal(12, 2)
  currency      String?
  imageUrl      String?
  available     Boolean  @default(true)
  specs         Json     @default("{}")
  variants      Json     @default("[]")
  shopifyUpdatedAt DateTime?                  // Shopify's updated_at — for OOO detection
  searchTsv     Unsupported("tsvector")?      // GIN-indexed via raw SQL
  embedding     Unsupported("vector(1024)")?  // Voyage AI voyage-3-lite
  deletedAt     DateTime?                     // soft delete
  indexedAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([handle])
  @@index([vendor])
  @@index([category])
  @@index([deletedAt])
  @@map("products")
}

// ============================================
// SHOPIFY SESSION MANAGEMENT
// ============================================

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)

  @@index([shop])
}

// ============================================
// CHAT & CONVERSATION MANAGEMENT
// ============================================

model Conversation {
  id              String    @id
  
  // Link to visitor/lead if available
  visitorId       String?
  visitor         Visitor?  @relation(fields: [visitorId], references: [id])
  
  // Shop information
  shopDomain      String?
  shopId          String?
  
  // Metadata
  title           String?   @default("Chat")
  status          ConversationStatus @default(ACTIVE)
  
  // Analytics
  messageCount    Int       @default(0)
  toolCallCount   Int       @default(0)

  // Last retrieval state — used to seed query understanding on follow-up turns (v6 pipeline)
  lastShownCategory String?
  lastShownBrands   String[]  @default([])

  // Timestamps
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  endedAt         DateTime?
  
  // Relations
  messages        Message[]
  analytics       ChatAnalytics[]

  @@index([visitorId])
  @@index([shopDomain])
  @@index([createdAt])
  @@index([status])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  // Message content
  role           String       // "user" or "assistant"
  content        String       // JSON string or plain text
  contentType    ContentType  @default(TEXT)
  
  // Metadata for analytics
  toolName       String?      // If this was a tool call
  tokenCount     Int?         // Approximate token count
  responseTimeMs Int?         // How long it took to generate
  
  // Timestamps
  createdAt      DateTime     @default(now())

  @@index([conversationId])
  @@index([createdAt])
  @@index([role])
}

enum ConversationStatus {
  ACTIVE
  ENDED
  ARCHIVED
}

enum ContentType {
  TEXT
  JSON
  TOOL_CALL
  TOOL_RESULT
  ERROR
}

// ============================================
// VISITOR & LEAD MANAGEMENT
// ============================================

model Visitor {
  id              String    @id @default(cuid())
  
  // Identification
  fingerprintId   String?   @unique  // Browser fingerprint
  sessionId       String?             // Session identifier
  
  // Contact info (from email popup)
  email           String?
  emailVerified   Boolean   @default(false)
  emailCapturedAt DateTime?
  
  // Shop context
  shopDomain      String?
  
  // Device & location info
  userAgent       String?
  ipAddress       String?
  country         String?
  city            String?
  timezone        String?
  
  // Behavior tracking
  firstSeenAt     DateTime  @default(now())
  lastSeenAt      DateTime  @default(now())
  visitCount      Int       @default(1)
  pageViews       Int       @default(0)
  
  // Engagement
  totalChats      Int       @default(0)
  totalMessages   Int       @default(0)
  
  // Lead status
  leadStatus      LeadStatus @default(VISITOR)
  leadScore       Int        @default(0)
  
  // UTM tracking
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?
  utmTerm         String?
  utmContent      String?
  
  // Relations
  conversations   Conversation[]
  
  // Timestamps
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([email])
  @@index([shopDomain])
  @@index([leadStatus])
  @@index([createdAt])
}

enum LeadStatus {
  VISITOR         // Just browsing
  ENGAGED         // Started a conversation
  LEAD            // Provided email
  QUALIFIED       // High engagement score
  CONVERTED       // Made a purchase
}

// ============================================
// LEADS TABLE (Email Captures)
// ============================================

model Lead {
  id              String    @id @default(cuid())
  
  // Contact information
  email           String
  
  // Shop context
  shopDomain      String
  shopId          String?
  
  // Capture context
  conversationId  String?   // Which conversation they were in
  captureSource   String    @default("chat_popup")  // Where email was captured
  capturedPage    String?   // URL where captured
  
  // Status
  status          LeadEmailStatus @default(NEW)
  
  // Marketing consent
  marketingConsent Boolean  @default(false)
  
  // Timestamps
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([email, shopDomain])
  @@index([shopDomain])
  @@index([status])
  @@index([createdAt])
}

enum LeadEmailStatus {
  NEW
  CONTACTED
  SUBSCRIBED
  UNSUBSCRIBED
}

// ============================================
// ANALYTICS
// ============================================

model ChatAnalytics {
  id              String       @id @default(cuid())
  conversationId  String
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  // Event tracking
  eventType       AnalyticsEventType
  eventData       Json?
  
  // Context
  shopDomain      String?
  userAgent       String?
  
  // Timestamps
  createdAt       DateTime     @default(now())

  @@index([conversationId])
  @@index([eventType])
  @@index([createdAt])
}

enum AnalyticsEventType {
  CHAT_STARTED
  CHAT_ENDED
  MESSAGE_SENT
  MESSAGE_RECEIVED
  TOOL_CALLED
  PRODUCT_VIEWED
  PRODUCT_ADDED_TO_CART
  CHECKOUT_INITIATED
  AUTH_REQUIRED
  AUTH_COMPLETED
  ERROR_OCCURRED
  EMAIL_CAPTURED
}

// ============================================
// AUTHENTICATION (OAuth Flow)
// ============================================

model CustomerToken {
  id              String    @id
  conversationId  String
  accessToken     String
  refreshToken    String?
  expiresAt       DateTime
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([conversationId])
}

model CodeVerifier {
  id              String    @id
  state           String    @unique
  verifier        String
  createdAt       DateTime  @default(now())
  expiresAt       DateTime

  @@index([state])
  @@index([expiresAt])
}

model CustomerAccountUrls {
  id               String    @id @default(cuid())
  conversationId   String    @unique
  mcpApiUrl        String?
  authorizationUrl String?
  tokenUrl         String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}
